# RPC endpoint
RPC_URL=http://localhost:8545

# ASP Registry Hub contract address
ASP_REGISTRY_ADDRESS=0x...

# Address to watch for events (pool address or token address)
WATCH_ADDRESS=0x...

# Event source mode:
#   pool — watch Shielded events on UPP pool (depositors get whitelisted)
#   mint — watch Transfer(from=0x0) events on ERC20 (minters get whitelisted)
WATCH_MODE=pool

# Block number to start indexing from (skip empty blocks before deployment)
DEPLOY_BLOCK=0

# Private key for the ASP operator (publishes roots on-chain)
OPERATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ASP ID (set after first registration, or leave empty to auto-register)
ASP_ID=

# API server port
PORT=3001

# Sanctions blocklist (comma-separated addresses, empty = everyone passes)
SANCTIONS_BLOCKLIST=

# Sepolia-specific (for Subsquid entry point)
SUBSQUID_ARCHIVE=https://v2.archive.subsquid.io/network/ethereum-sepolia
