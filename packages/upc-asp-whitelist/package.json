{
  "name": "@permissionless-technologies/upc-asp-whitelist",
  "version": "0.5.1",
  "description": "Auto-whitelist ASP service — watches on-chain events and automatically whitelists addresses after sanctions screening",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev:local": "tsx src/local.ts",
    "dev:sepolia": "tsx src/sepolia.ts"
  },
  "keywords": [
    "upc",
    "asp",
    "whitelist",
    "compliance",
    "zero-knowledge",
    "ethereum"
  ],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@permissionless-technologies/upc-sdk": "^0.3.2",
    "express": "^4.18.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "optionalDependencies": {
    "@subsquid/evm-processor": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
