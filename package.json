{
  "name": "@permissionless-technologies/upc-sdk",
  "version": "0.4.0",
  "description": "Universal Private Compliance SDK — Pluggable zero-knowledge attestation & ASP (Association Set Provider) framework",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "require": "./dist/providers/index.cjs"
    },
    "./operator": {
      "types": "./dist/operator/index.d.ts",
      "import": "./dist/operator/index.js",
      "require": "./dist/operator/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./asp": {
      "types": "./dist/asp/index.d.ts",
      "import": "./dist/asp/index.js",
      "require": "./dist/asp/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "deployments"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "dev:asp-local": "tsx packages/upc-asp-whitelist/src/local.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "ethereum",
    "privacy",
    "compliance",
    "asp",
    "association-set-provider",
    "zero-knowledge",
    "zk",
    "attestation",
    "merkle-tree",
    "identity",
    "kyc",
    "viem"
  ],
  "author": "",
  "license": "AGPL-3.0-or-later",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "wagmi": {
      "optional": true
    }
  },
  "dependencies": {
    "circomlibjs": "^0.1.7",
    "poseidon-bls12381": "^1.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0 || ^19.0.0",
    "circomlib": "^2.0.5",
    "husky": "^9.1.7",
    "poseidon-bls12381-circom": "^1.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "viem": "^2.0.0",
    "vitest": "^1.0.0",
    "wagmi": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
